package com.DSA;

public class Day2_Diamond_Pattern {
	public static void main(String[] args) {
		int n = 4;
		for (int i = 1; i <= 4; i++) {
			for (int j = 1; j <= (n - i); j++) {
				System.out.print(" ");
			}
			
			
			for (int j = 1; j <= (j + 2); j++) {
				if (j == 7 || j == 8) {
					break;
				}
				System.out.println("*");
			}
			System.out.println();
		}

	}
}