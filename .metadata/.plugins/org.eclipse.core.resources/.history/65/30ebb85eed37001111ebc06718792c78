package com.DSA;

public class Day1_Pattern_9 {
	// for 0 1 triangle
	public static void main(String[] args) {
		int cnt = 1;

		for (int i = 1; i <= 5; i++) {
			for (int j = 1; j <= i; j++) {
				if (cnt == 1) {
					System.out.print(cnt + " ");
					cnt = 0;
				} else {
					System.out.print(cnt + " ");
					cnt = 1;
				}

			}
			System.out.println();
		}
	}

}
