package com.DSA;

public class Day2_Number_pyramid {

	public static void main(String[] args) {
		int n = 5;
		int count = 1;
		for (int i = 1; i <= n; i++) {
			for (int j = 4; j >= i; j--) {
				System.out.print(" ");
			}
			for (int k = 1; k <= i; k++) {
				System.out.print(count);
			}
			count++;
		}
	}

}
